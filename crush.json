{
  "mcpServers": {
    "basic-memory": {
      "command": "uvx",
      "args": ["basic-memory", "mcp"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "kubernetes": {
      "command": "python",
      "args": ["-m", "kubectl_mcp_tool.minimal_wrapper"],
      "env": {
        "KUBECONFIG": "~/.kube/config",
        "AWS_PROFILE": "dev-provisioner",
        "MCP_LOG_FILE": "/tmp/kubectl-mcp.log"
      },
      "timeout": 30000
    },
    "gitlab": {
      "command": "docker",
      "args": [
        "run", "-i", "--rm", "-e", "GITLAB_API_URL", "-e", "GITLAB_PERSONAL_ACCESS_TOKEN",
        "mcp/gitlab"
      ],
      "env": {
        "GITLAB_API_URL": "https://gitlab.com/api/v4",
        "GITLAB_PERSONAL_ACCESS_TOKEN": "$GITLAB_TOKEN"
      }
    },
    "aws-core": {
      "command": "docker",
      "args": [
        "run", "--rm", "-i", "ghcr.io/astral-sh/uv:debian",
        "uvx", "awslabs.core-mcp-server@latest"
      ],
      "env": {"FASTMCP_LOG_LEVEL": "ERROR"}
    },
    "aws-docs": {
      "command": "docker",
      "args": [
        "run", "--rm", "-i", "ghcr.io/astral-sh/uv:debian",
        "uvx", "awslabs.aws-documentation-mcp-server@latest"
      ],
      "env": {"FASTMCP_LOG_LEVEL": "ERROR"}
    },
    "aws-tf": {
      "command": "docker",
      "args": [
        "run", "--rm", "-i", "ghcr.io/astral-sh/uv:debian",
        "uvx", "awslabs.terraform-mcp-server@latest"
      ],
      "env": {"FASTMCP_LOG_LEVEL": "ERROR"}
    },
    "aws-diagram": {
      "command": "docker",
      "args": [
        "run", "--rm", "-i", "ghcr.io/astral-sh/uv:debian",
        "uvx", "awslabs.aws-diagram-mcp-server@latest"
      ],
      "env": {"FASTMCP_LOG_LEVEL": "ERROR"}
    }
  },
  "environments": {
    "default": {
      "PATH": "/opt/homebrew/bin:~/.local/share/mise/installs/python/3.13.1/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin",
      "AWS_PROFILE": "dev-provisioner"
    }
  },
  "config": {
    "systemPath": "~/.crush.json",
    "projectPath": ".crush.json",
    "mcpPath": "~/.config/mcp/crush.json"
  }
}