{
    "mcpServers": {
        "basic-memory": {
            "command": "uvx",
            "args": [
                "basic-memory",
                "mcp"
            ]
        },
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp@latest"
            ]
        },
        "kubernetes": {
            "command": "python",
            "args": [
                "-m",
                "kubectl_mcp_tool.minimal_wrapper"
            ],
            "env": {
                "KUBECONFIG": "/Users/chaz.straney@getgarner.com/.kube/config",
                "PATH": "/opt/homebrew/bin:/Users/chaz.straney@getgarner.com/.local/share/mise/installs/python/3.13.1/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin",
                "AWS_PROFILE": "dev-provisioner",
                "MCP_LOG_FILE": "/tmp/kubectl-mcp.log"
            },
            "protocol": {
                "type": "jsonrpc",
                "version": "2.0",
                "initializeParams": {
                    "protocolVersion": "0.1.0",
                    "capabilities": {},
                    "clientInfo": {
                        "name": "augment",
                        "version": "1.0.0"
                    }
                },
                "toolsMethod": "tools/list"
            },
            "timeout": 30000
        },
        "gitlab": {
            "command": "docker",
            "args": [
                "run",
                "-i",
                "--rm",
                "-e",
                "GITLAB_API_URL",
                "-e",
                "GITLAB_PERSONAL_ACCESS_TOKEN",
                "mcp/gitlab"
            ],
            "env": {
                "GITLAB_API_URL": "https://gitlab.com/api/v4",
                "GITLAB_PERSONAL_ACCESS_TOKEN": "glpat-QkDYKbsRiPyTIio_kGeCC286MQp1OmZmbnNsCw.01.121dot3rs"
            },
            "protocol": {
                "type": "jsonrpc",
                "version": "2.0",
                "initializeParams": {
                    "protocolVersion": "0.1.0",
                    "capabilities": {},
                    "clientInfo": {
                        "name": "augment",
                        "version": "1.0.0"
                    }
                },
                "toolsMethod": "tools/list"
            }
        },
        "aws-core": {
            "command": "docker",
            "args": [
                "run",
                "--rm",
                "-i",
                "ghcr.io/astral-sh/uv:debian",
                "uvx",
                "awslabs.core-mcp-server@latest"
            ],
            "env": {
                "FASTMCP_LOG_LEVEL": "ERROR"
            },
            "protocol": {
                "type": "jsonrpc",
                "version": "2.0",
                "initializeParams": {
                    "protocolVersion": "0.1.0",
                    "capabilities": {},
                    "clientInfo": {
                        "name": "augment",
                        "version": "1.0.0"
                    }
                },
                "toolsMethod": "tools/list"
            }
        },
        "aws-docs": {
            "command": "docker",
            "args": [
                "run",
                "--rm",
                "-i",
                "ghcr.io/astral-sh/uv:debian",
                "uvx",
                "awslabs.aws-documentation-mcp-server@latest"
            ],
            "env": {
                "FASTMCP_LOG_LEVEL": "ERROR"
            },
            "protocol": {
                "type": "jsonrpc",
                "version": "2.0",
                "initializeParams": {
                    "protocolVersion": "0.1.0",
                    "capabilities": {},
                    "clientInfo": {
                        "name": "augment",
                        "version": "1.0.0"
                    }
                },
                "toolsMethod": "tools/call",
                "defaultTool": "search_documentation"
            }
        },
        "aws-tf": {
            "command": "docker",
            "args": [
                "run",
                "--rm",
                "-i",
                "ghcr.io/astral-sh/uv:debian",
                "uvx",
                "awslabs.terraform-mcp-server@latest"
            ],
            "env": {
                "FASTMCP_LOG_LEVEL": "ERROR"
            },
            "protocol": {
                "type": "jsonrpc",
                "version": "2.0",
                "initializeParams": {
                    "protocolVersion": "0.1.0",
                    "capabilities": {},
                    "clientInfo": {
                        "name": "augment",
                        "version": "1.0.0"
                    }
                },
                "toolsMethod": "tools/list"
            }
        },
        "aws_diagram": {
            "command": "docker",
            "args": [
                "run",
                "--rm",
                "-i",
                "ghcr.io/astral-sh/uv:debian",
                "uvx",
                "awslabs.aws-diagram-mcp-server@latest"
            ],
            "env": {
                "FASTMCP_LOG_LEVEL": "ERROR"
            },
            "protocol": {
                "type": "jsonrpc",
                "version": "2.0",
                "initializeParams": {
                    "protocolVersion": "0.1.0",
                    "capabilities": {},
                    "clientInfo": {
                        "name": "augment",
                        "version": "1.0.0"
                    }
                },
                "toolsMethod": "tools/call",
                "defaultTool": "get_diagram_examples"
            }
        }
    }
}
