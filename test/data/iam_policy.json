{
  "PolicyName": "S3BucketAccessPolicy",
  "PolicyId": "ANPA0A1B2C3D4E5F6789",
  "Arn": "arn:aws:iam::123456789012:policy/S3BucketAccessPolicy",
  "Path": "/",
  "DefaultVersionId": "v3",
  "AttachmentCount": 5,
  "PermissionsBoundaryUsageCount": 0,
  "IsAttachable": true,
  "CreateDate": "2024-01-10T08:00:00Z",
  "UpdateDate": "2024-11-15T14:30:00Z",
  "Description": "Policy for accessing application S3 buckets",
  "PolicyDocument": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "ListBuckets",
        "Effect": "Allow",
        "Action": ["s3:ListAllMyBuckets", "s3:GetBucketLocation"],
        "Resource": "*"
      },
      {
        "Sid": "AccessAppBuckets",
        "Effect": "Allow",
        "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject", "s3:ListBucket"],
        "Resource": [
          "arn:aws:s3:::my-app-data-*",
          "arn:aws:s3:::my-app-data-*/*"
        ]
      }
    ]
  },
  "Tags": [
    {"Key": "ManagedBy", "Value": "terraform"},
    {"Key": "Application", "Value": "my-app"}
  ]
}
